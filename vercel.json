{
    "version": 2,
    "routes": [
        {
            "src": "/build/(.*)", 
            "dest": "/public/build/$1"
        },
        {
            "src": "/css/(.*)", 
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)", 
            "dest": "/public/js/$1"
        },
        {
            "src": "/(.*)", 
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://taller-ucv.vercel.app"
    }
}