{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "@vercel/laravel"
        },
        {
            "src": "public/**",
            "use": "static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://taller-ucv.vercel.app"
    }
}